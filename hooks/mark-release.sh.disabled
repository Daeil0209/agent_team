#!/usr/bin/env bash
set -euo pipefail
# Released state removed (P8). Redirecting to force-stop.
source "$(dirname "$0")/hook-config.sh"
AGENT_NAME="${1:?Usage: mark-release.sh <worker-name>}"
echo "DEPRECATED: Released state removed. Redirecting to force-stop." >&2
exec "$HOOK_DIR/mark-force-stop.sh" "$AGENT_NAME"
